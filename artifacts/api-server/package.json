{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "export NODE_ENV=development && esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=cjs --external:@workspace/db --external:@workspace/api-zod && cross-env PORT=3001 node -r dotenv/config --enable-source-maps ./dist/index.js",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=cjs --external:@workspace/db --external:@workspace/api-zod",
    "start": "node -r dotenv/config --enable-source-maps ./dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.14.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "axios": "^1.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.30.0",
    "express": "^5.0.0-beta.1",
    "nodemailer": "^8.0.7",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "cross-env": "^7.0.3",
    "esbuild": "0.25.8",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}
